# Database
DATABASE_URL=postgresql+asyncpg://iip_user:iip_password@localhost:5432/incidentiq

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333

# Redis Cache & Job Queue
REDIS_URL=redis://localhost:6379

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here_generate_with_openssl_rand_base64_32

# OAuth Providers
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Cohere (optional, for reranker)
COHERE_API_KEY=your_cohere_api_key_here_optional
