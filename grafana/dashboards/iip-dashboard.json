{
  "dashboard": {
    "title": "Incident Intelligence Platform - Overview",
    "tags": ["iip", "rag", "incidents"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Query Latency (p50/p95/p99)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(iip_query_latency_seconds_bucket[5m]))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(iip_query_latency_seconds_bucket[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(iip_query_latency_seconds_bucket[5m]))",
            "legendFormat": "p99"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Retrieval Score (Top-1)",
        "type": "graph",
        "targets": [
          {
            "expr": "avg(iip_retrieval_score_top1)",
            "legendFormat": "avg top-1 score"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "Queries per Hour",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(iip_query_latency_seconds_count[1h])",
            "legendFormat": "queries/hour"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "Feedback Ratio",
        "type": "stat",
        "targets": [
          {
            "expr": "iip_query_feedback_positive_total / (iip_query_feedback_positive_total + iip_query_feedback_negative_total)",
            "legendFormat": "positive ratio"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 8}
      },
      {
        "id": 5,
        "title": "LLM Tokens Used",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(iip_llm_tokens_used_total[5m])",
            "legendFormat": "tokens/sec"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 8}
      }
    ],
    "schemaVersion": 16,
    "version": 1
  }
}
